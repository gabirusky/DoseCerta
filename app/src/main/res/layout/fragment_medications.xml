<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:text="@string/medications_title"
            android:textAppearance="@style/TextAppearance.DoseCerta.Headline"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Search -->
        <androidx.appcompat.widget.SearchView
            android:id="@+id/search_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_small"
            android:background="@drawable/search_background"
            app:iconifiedByDefault="false"
            app:queryHint="@string/medications_search_hint" />

        <!-- Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:scrollbars="none"
            android:clipToPadding="false">

            <com.google.android.material.chip.ChipGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:singleLine="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_all"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/medications_filter_all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_daily"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/medications_filter_daily" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_every_4_hours"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/medications_filter_every_4_hours" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_every_6_hours"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/medications_filter_every_6_hours" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_every_8_hours"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/medications_filter_every_8_hours" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_every_12_hours"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/medications_filter_every_12_hours" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_as_needed"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/medications_filter_as_needed" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Medications List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_medications"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Empty State -->
        <TextView
            android:id="@+id/text_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/medications_empty"
            android:textAppearance="@style/TextAppearance.DoseCerta.Body"
            android:visibility="gone" />
    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/fab_margin"
        android:contentDescription="@string/cd_add_medication"
        app:srcCompat="@drawable/ic_add"
        app:tint="@color/white"
        style="@style/Widget.DoseCerta.FloatingActionButton" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
