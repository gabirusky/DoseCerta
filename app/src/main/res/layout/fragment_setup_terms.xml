<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50">

    <!-- Header with Icon and Title -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Shield Icon -->
        <ImageView
            android:id="@+id/icon_privacy"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_shield_privacy"
            android:contentDescription="@string/privacy_policy_title"
            app:tint="@color/verdigris" />

        <!-- Main Title -->
        <TextView
            android:id="@+id/text_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/privacy_summary_title"
            android:textAppearance="@style/TextAppearance.DoseCerta.Headline"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/baltic_blue_dark"
            android:gravity="center" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/text_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/privacy_summary_subtitle"
            android:textAppearance="@style/TextAppearance.DoseCerta.Body"
            android:textSize="14sp"
            android:textColor="@color/gray_600"
            android:gravity="center" />

    </LinearLayout>

    <!-- Summary Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/header_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Summary Item 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/mint_leaf" />
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/privacy_summary_item_1"
                    android:textAppearance="@style/TextAppearance.DoseCerta.Body"
                    android:textSize="14sp"
                    android:textColor="@color/gray_800" />
            </LinearLayout>

            <!-- Summary Item 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/mint_leaf" />
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/privacy_summary_item_2"
                    android:textAppearance="@style/TextAppearance.DoseCerta.Body"
                    android:textSize="14sp"
                    android:textColor="@color/gray_800" />
            </LinearLayout>

            <!-- Summary Item 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/mint_leaf" />
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/privacy_summary_item_3"
                    android:textAppearance="@style/TextAppearance.DoseCerta.Body"
                    android:textSize="14sp"
                    android:textColor="@color/gray_800" />
            </LinearLayout>

            <!-- Summary Item 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/mint_leaf" />
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/privacy_summary_item_4"
                    android:textAppearance="@style/TextAppearance.DoseCerta.Body"
                    android:textSize="14sp"
                    android:textColor="@color/gray_800" />
            </LinearLayout>

            <!-- Summary Item 5 (LGPD) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/mint_leaf" />
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/privacy_summary_item_5"
                    android:textAppearance="@style/TextAppearance.DoseCerta.Body"
                    android:textSize="14sp"
                    android:textColor="@color/gray_800" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Full Policy Section Title -->
    <TextView
        android:id="@+id/text_full_policy_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:text="@string/privacy_full_policy_label"
        android:textAppearance="@style/TextAppearance.DoseCerta.Body"
        android:textSize="13sp"
        android:textColor="@color/gray_600"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/card_summary"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Full Privacy Policy Small Card (Scrollable) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_full_policy"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@color/gray_100"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/text_full_policy_label"
        app:layout_constraintBottom_toTopOf="@id/checkbox_accept"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_max="160dp">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fadingEdge="vertical"
            android:requiresFadingEdge="vertical"
            android:fadingEdgeLength="16dp">

            <TextView
                android:id="@+id/text_privacy_policy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="@string/privacy_policy_full_text"
                android:textAppearance="@style/TextAppearance.DoseCerta.Body"
                android:textSize="11sp"
                android:textColor="@color/gray_700"
                android:lineSpacingMultiplier="1.3" />

        </androidx.core.widget.NestedScrollView>

    </com.google.android.material.card.MaterialCardView>

    <!-- Checkbox for acceptance -->
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkbox_accept"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:text="@string/setup_terms_checkbox"
        android:textAppearance="@style/TextAppearance.DoseCerta.Body"
        android:textSize="14sp"
        android:buttonTint="@color/verdigris"
        app:layout_constraintBottom_toTopOf="@id/button_continue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Continue Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_continue"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:text="@string/setup_terms_button"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:enabled="false"
        android:backgroundTint="@color/verdigris"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
