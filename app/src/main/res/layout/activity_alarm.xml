<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_100">

    <!-- Main Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_alarm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Alarm Icon -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:contentDescription="@string/cd_medication_icon"
                android:src="@drawable/ic_pill"
                app:tint="@color/baltic_blue" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:text="@string/alarm_title"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="@color/gray_900"
                android:textStyle="bold" />

            <!-- Medication Name -->
            <TextView
                android:id="@+id/text_medication_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="4dp"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textColor="@color/baltic_blue"
                android:textStyle="bold"
                tools:text="Paracetamol" />

            <!-- Dosage Info -->
            <TextView
                android:id="@+id/text_dosage_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="@color/gray_700"
                tools:text="500 mg - Comprimido" />

            <!-- Scheduled Time -->
            <TextView
                android:id="@+id/text_scheduled_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/gray_700"
                tools:text="Programado para 08:00" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="24dp"
                android:background="@color/gray_300" />

            <!-- Action Buttons -->
            
            <!-- Take Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_alarm_take"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="@string/notification_action_take"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_pill"
                app:iconGravity="textStart" />

            <!-- Skip Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_alarm_skip"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:text="@string/notification_action_skip"
                android:textSize="16sp"
                app:cornerRadius="12dp" />

            <!-- Snooze Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_alarm_snooze"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/notification_action_snooze"
                android:textSize="16sp"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
