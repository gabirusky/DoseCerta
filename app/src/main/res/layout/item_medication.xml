<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_small"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_medium"
        android:gravity="center_vertical">

        <!-- Medication Icon -->
        <ImageView
            android:id="@+id/image_medication_icon"
            android:layout_width="@dimen/medication_icon_size"
            android:layout_height="@dimen/medication_icon_size"
            android:src="@drawable/ic_circle"
            android:contentDescription="@string/cd_medication_icon" />

        <!-- Medication Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_medium"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_medication_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Desvenlafaxina"
                android:textAppearance="@style/TextAppearance.DoseCerta.Title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_dosage_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100 mg - Comprimido"
                android:textAppearance="@style/TextAppearance.DoseCerta.Body"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/text_frequency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/frequency_badge_background"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Diário"
                android:textColor="?attr/colorSecondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Action Buttons -->
        <ImageButton
            android:id="@+id/button_edit"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_edit_medication"
            android:src="@drawable/ic_edit"
            app:tint="?attr/colorOnSurfaceVariant" />

        <ImageButton
            android:id="@+id/button_delete"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_delete_medication"
            android:src="@drawable/ic_delete"
            app:tint="@color/status_missed" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
