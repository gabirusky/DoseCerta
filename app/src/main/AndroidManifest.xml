<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================= -->
    <!-- CORE PERMISSIONS - Android Standard           -->
    <!-- ============================================= -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    
    <!-- ============================================= -->
    <!-- ALARM & SCHEDULING PERMISSIONS                -->
    <!-- Required for: All devices                     -->
    <!-- ============================================= -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    
    <!-- ============================================= -->
    <!-- FOREGROUND SERVICE PERMISSIONS                -->
    <!-- Required for: Android 8+ (Oreo)               -->
    <!-- ============================================= -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    
    <!-- ============================================= -->
    <!-- FULL-SCREEN INTENT & WAKE PERMISSIONS         -->
    <!-- Required for: Lock screen alarm display       -->
    <!-- ============================================= -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- ============================================= -->
    <!-- MANUFACTURER-SPECIFIC COMPATIBILITY           -->
    <!-- ============================================= -->
    
    <!-- Xiaomi (MIUI / HyperOS) -->
    <!-- Requires: Autostart, Battery restrictions off, Show on lock screen -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    
    <!-- Samsung (One UI) -->
    <!-- Requires: Sleeping apps whitelist, Battery optimization off -->
    <!-- Uses standard permissions above -->
    
    <!-- Huawei (EMUI / HarmonyOS) -->
    <!-- Requires: App Launch settings, Ignore battery optimization -->
    <!-- Uses standard permissions above -->

    <application
        android:name=".DoseCertaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DoseCerta"
        tools:targetApi="31">
        
        <!-- Main Activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.DoseCerta">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Setup/Onboarding Activity -->
        <activity
            android:name=".ui.setup.SetupActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.DoseCerta" />
        
        <!-- Alarm Activity -->
        <activity
            android:name=".alarm.AlarmActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/Theme.DoseCerta" />
        
        <!-- Alarm Service -->
        <service
            android:name=".alarm.AlarmService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />
        
        <!-- Alarm Receiver -->
        <receiver
            android:name=".alarm.MedicationAlarmReceiver"
            android:enabled="true"
            android:exported="false" />
        
        <!-- Boot Completed Receiver -->
        <receiver
            android:name=".alarm.BootCompletedReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        
        <!-- Notification Action Receiver -->
        <receiver
            android:name=".notification.NotificationActionReceiver"
            android:enabled="true"
            android:exported="false" />
        
        <!-- Mark Missed Receiver -->
        <receiver
            android:name=".notification.MarkMissedReceiver"
            android:enabled="true"
            android:exported="false" />
        
        <!-- Missed Reminder Receiver -->
        <receiver
            android:name=".notification.MissedReminderReceiver"
            android:enabled="true"
            android:exported="false" />

    </application>

</manifest>
